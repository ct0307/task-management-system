# ============================================
# 轻量化任务管理系统 — 生产环境变量
# 部署到服务器前请修改以下密码！
# ============================================

# 数据库
DB_PASSWORD=请修改为随机强密码_至少16位
DB_NAME=task_system_db

# JWT（用于生成登录Token，请修改为随机字符串）
JWT_SECRET=请修改为随机字符串_至少32位
JWT_EXPIRES_IN=7d

# CORS（部署后改为你的域名）
CORS_ORIGIN=http://localhost

# 可选：开启 Swagger 文档
# ENABLE_SWAGGER=true
