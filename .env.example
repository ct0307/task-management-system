# ============================================
# 轻量化任务管理系统 — 环境变量模板
# 复制此文件为 .env 后修改
#   cp .env.example .env
# ============================================

# 数据库密码
DB_PASSWORD=change_me_to_secure_password

# 数据库名
DB_NAME=task_system_db

# JWT 密钥（生产环境务必修改为随机长字符串！）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_random_secret_key_2026

# JWT 过期时间
JWT_EXPIRES_IN=7d

# CORS 允许的前端域名
# 本地: http://localhost
# 生产: https://your-domain.com
CORS_ORIGIN=http://localhost
