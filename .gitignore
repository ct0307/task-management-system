# 构建产物
# ============================================
dist/
build/
*.tsbuildinfo

# ============================================
# 编辑器 / IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# 日志
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# 测试
# ============================================
coverage/
.nyc_output/

# ============================================
# 临时文件
# ============================================
*.bak
*.tmp
*.temp
.atomcode/

# Python 缓存
__pycache__/
*.pyc

# 数据库备份
backups/
deploy.py
aliyun_cmd.py
fix_swas.py
swas_fix.py
swas_optimize.py

# 截图/临时图片
*.png
*.jpg

