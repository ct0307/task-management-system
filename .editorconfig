# EditorConfig — 跨编辑器统一缩进/换行
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,css,less,html,md,yaml,yml}]
indent_style = space
indent_size = 2

[*.{md,rst}]
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
